{
  "name": "interceptjs",
  "version": "0.1.0",
  "description": "A non-destructive DOM intercept layer with AI-powered patching",
  "main": "./dist/interceptjs.iife.js",
  "module": "./dist/interceptjs.js",
  "types": "./dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/interceptjs.js",
      "browser": "./dist/interceptjs.iife.js"
    }
  },
  "scripts": {
    "build": "BUILD_ENTRY=interceptjs vite build && BUILD_ENTRY=cuttlefish vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "dom",
    "intercept",
    "overlay",
    "non-destructive",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.3",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  }
}