# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/kuttl_db?sslmode=disable

# PostgreSQL Connection Pool Settings (optional - uses defaults if not set)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5
DB_CONN_MAX_IDLE_TIME_MINUTES=2

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24
API_TOKEN_PREFIX=kuttl_

# AI Provider Configuration
AI_PROVIDER=openai
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# Server Configuration
PORT=8080
ALLOWED_ORIGINS=*
RATE_LIMIT=5

# Logging
LOG_LEVEL=info
LOG_FILE=logs/requests.log