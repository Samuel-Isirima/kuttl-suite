{
  "name": "@cuttlefish/react",
  "version": "0.1.0",
  "description": "Cuttlefish React adapter — AI-powered non-destructive UI patching for React apps",
  "type": "module",

  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },

  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },

  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },

  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}